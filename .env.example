# Variables de entorno necesarias para el bot
# Copia este archivo como .env y completa los valores

# Token del bot de Telegram (lo obtienes de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# ID de tu Google Sheet (lo sacas de la URL: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Credenciales de la cuenta de servicio de Google (el contenido COMPLETO del archivo JSON en una sola línea)
# En Railway: pega todo el contenido del archivo bot-facsisoft-655f3545d3ba.json aquí
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
